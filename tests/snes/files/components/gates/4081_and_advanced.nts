# This is the 4081 but with some inputs linked to itself
#
# Test of AND logic gate (4081)
#
#           +---------4081---------+
# in_01  -1-|>-+---\       ignored-|-14-
#           |  | &  |-+            |
# in_02  -2-|>-+---/  |     /---+-<|-13- in_13
#           |         |  +-|  & |  |
# out_03 -3-|<--------+  |  \---+-<|-12- in_12
#           |            |         |
# out_04 -4-|<--------+  +-------->|-11- out_11
#           |         |            |
# in_05  -5-|>-+---\  |  +-------->|-10- out_10
#           |  | &  |-+  |         |
# in_06  -6-|>-+---/     |  /---+-<|-9-  in_09
#           |            +-|  & |  |
#        -7-|-ignored       \---+-<|-8-  in_08
#           +----------------------+

.chipsets:
input in_01
input in_02
input in_06
input in_09
output out_11
input in_13
4081 gate

.links:
in_01:1 gate:1
in_02:1 gate:2
gate:3 gate:5 # Output of the first linked to the first input of the second
in_06:1 gate:6
gate:4 gate:8 # Output of the second linked to the first input of the third
in_09:1 gate:9
gate:10 gate:12 # Output of the third linked to the first input of the
in_13:1 gate:13
out_11:1 gate:11

